local unpackValues = table.unpack or unpack

local function packValues(...)
	return { n = select("#", ...), ... }
end

local function normalizeLogText(text)
	text = tostring(text or "")
	text = text:gsub("\r", " "):gsub("\n", "  ")
	return text
end

local function makeTraceback(err)
	local message = tostring(err or "erro desconhecido")
	if debug and type(debug.traceback) == "function" then
		local ok, trace = pcall(debug.traceback, message, 2)
		if ok and trace then
			return normalizeLogText(trace)
		end
	end

	return normalizeLogText(message)
end

local function pushConsole(level, message, source)
	local entry = {
		time = os.date("%H:%M:%S"),
		level = tostring(level or "Info"),
		source = tostring(source or "Interface"),
		message = normalizeLogText(message),
	}

	table.insert(InternalConsole.entries, 1, entry)
	while #InternalConsole.entries > InternalConsole.maxEntries do
		table.remove(InternalConsole.entries)
	end

	if InternalConsole.refresh then
		task.defer(function()
			pcall(InternalConsole.refresh)
		end)
	end
end

local function safeCall(source, fn, ...)
	if type(fn) ~= "function" then
		return false
	end

	local args = packValues(...)
	local results = nil
	local ok, err = xpcall(function()
		results = packValues(fn(unpackValues(args, 1, args.n)))
	end, makeTraceback)

	if not ok then
		pushConsole("Erro", err, source)
		return false
	end

	if results then
		return true, unpackValues(results, 1, results.n)
	end

	return true
end

local function messageTypeToLevel(messageType)
	if messageType == Enum.MessageType.MessageError then
		return "Erro"
	elseif messageType == Enum.MessageType.MessageWarning then
		return "Aviso"
	elseif messageType == Enum.MessageType.MessageInfo then
		return "Info"
	end

	return "Log"
end

LogService.MessageOut:Connect(function(message, messageType)
	pcall(function()
		pushConsole(messageTypeToLevel(messageType), message, "Output")
	end)
end)

local function getFontRole(font)
	if font == FONT_BODY_BOLD then
		return "Bold"
	elseif font == FONT_BODY_MED then
		return "Medium"
	elseif font == FONT_MONO then
		return "Mono"
	end

	return "Body"
end

local function applyFontToInstance(inst, role)
	local preset = FONT_OPTIONS[AppState.fontName] or FONT_OPTIONS.Gotham
	local font = preset[role] or preset.Body

	local ok, err = pcall(function()
		inst.Font = font
	end)

	if not ok then
		pushConsole("Erro", err, "Font")
	end
end

local function registerTextFont(inst, sourceFont)
	if not (inst:IsA("TextLabel") or inst:IsA("TextButton") or inst:IsA("TextBox")) then
		return
	end

	local role = getFontRole(sourceFont or inst.Font)
	table.insert(textFontBindings, { inst = inst, role = role })
	applyFontToInstance(inst, role)
end

local function applyUIFont(fontName)
	if not FONT_OPTIONS[fontName] then
		return
	end

	AppState.fontName = fontName
	local alive = {}

	for _, binding in ipairs(textFontBindings) do
		if binding.inst and binding.inst.Parent then
			applyFontToInstance(binding.inst, binding.role)
			table.insert(alive, binding)
		end
	end

	textFontBindings = alive
end

local function getNextFontName()
	for index, fontName in ipairs(FONT_ORDER) do
		if fontName == AppState.fontName then
			return FONT_ORDER[(index % #FONT_ORDER) + 1]
		end
	end

	return FONT_ORDER[1]
end

local function keyText(keyCode)
	if typeof(keyCode) == "EnumItem" and keyCode ~= Enum.KeyCode.Unknown then
		return keyCode.Name
	end

	return ""
end

local function keyCodeFromName(name)
	if type(name) ~= "string" or name == "" then
		return Enum.KeyCode.Unknown
	end

	local ok, keyCode = pcall(function()
		return Enum.KeyCode[name]
	end)

	if ok and typeof(keyCode) == "EnumItem" then
		return keyCode
	end

	return Enum.KeyCode.Unknown
end

local function getSerializableKeybinds()
	local data = {}

	for id, keyCode in pairs(AppState.keybinds) do
		data[id] = keyText(keyCode)
	end

	return data
end

local function saveKeybinds()
	if type(writefile) ~= "function" then
		return false
	end

	local okEncode, encoded = pcall(function()
		return HttpService:JSONEncode(getSerializableKeybinds())
	end)

	if not okEncode then
		pushConsole("Aviso", tostring(encoded), "Keybinds")
		return false
	end

	local okWrite, writeErr = pcall(function()
		writefile(KEYBINDS_FILE, encoded)
	end)

	if not okWrite then
		pushConsole("Aviso", tostring(writeErr), "Keybinds")
	end

	return okWrite
end

local function loadSavedKeybinds()
	if type(readfile) ~= "function" then
		return
	end

	if type(isfile) == "function" then
		local okFile, exists = pcall(function()
			return isfile(KEYBINDS_FILE)
		end)

		if okFile and not exists then
			return
		end
	end

	local okRead, raw = pcall(function()
		return readfile(KEYBINDS_FILE)
	end)

	if not okRead or type(raw) ~= "string" or raw == "" then
		return
	end

	local okDecode, data = pcall(function()
		return HttpService:JSONDecode(raw)
	end)

	if not okDecode or type(data) ~= "table" then
		return
	end

	for id in pairs(AppState.keybinds) do
		AppState.keybinds[id] = keyCodeFromName(data[id])
	end
end

loadSavedKeybinds()

local function create(className, props)
	local okNew, inst = pcall(function()
		return Instance.new(className)
	end)

	if not okNew then
		pushConsole("Erro", tostring(inst), "Instance.new")
		inst = Instance.new("Frame")
	end

	for p, v in pairs(props) do
		local ok, err = pcall(function()
			inst[p] = v
		end)

		if not ok then
			pushConsole("Erro", ("%s.%s: %s"):format(className, tostring(p), tostring(err)), "create")
		end
	end
	registerTextFont(inst, props and props.Font)
	return inst
end

local function corner(parent, radius)
	create("UICorner", { CornerRadius = UDim.new(0, radius), Parent = parent })
	return parent
end

local function stroke(parent, color, thickness)
	return create("UIStroke", {
		Color = color or Theme.Line,
		Thickness = thickness or 1,
		Transparency = 1,
		Enabled = false,
		Parent = parent,
	})
end

local function tween(obj, props, time)
	local tweenProps = {}

	for prop, value in pairs(props) do
		if prop == "Text" then
			obj.Text = value
		else
			tweenProps[prop] = value
		end
	end

	if next(tweenProps) then
		local ok, tweenObj = pcall(function()
			return TweenService:Create(obj, TweenInfo.new(time or UI_TWEEN_TIME, Enum.EasingStyle.Quad), tweenProps)
		end)

		if ok and tweenObj then
			local playOk, playErr = pcall(function()
				tweenObj:Play()
			end)

			if not playOk then
				pushConsole("Erro", playErr, "TweenService")
			end
		else
			pushConsole("Erro", tweenObj, "TweenService")
		end
	end
end

local function applyProps(obj, props, animate)
	if animate then
		tween(obj, props, UI_TWEEN_TIME)
	else
		for p, v in pairs(props) do
			local ok, err = pcall(function()
				obj[p] = v
			end)

			if not ok then
				local objName = obj and obj.Name or "nil"
				pushConsole("Erro", ("%s.%s: %s"):format(objName, tostring(p), tostring(err)), "applyProps")
			end
		end
	end
end

local function bindTheme(inst, prop, themeKey)
	table.insert(themeBindings, { inst = inst, prop = prop, themeKey = themeKey })
	local ok, err = pcall(function()
		inst[prop] = Theme[themeKey]
	end)

	if not ok then
		pushConsole("Erro", ("%s.%s: %s"):format(inst.Name, tostring(prop), tostring(err)), "bindTheme")
	end
	return inst
end

local function addGlobalThemeRefresher(fn)
	table.insert(globalThemeRefreshers, fn)
	return fn
end

local function addViewThemeRefresher(fn)
	table.insert(viewThemeRefreshers, fn)
	return fn
end

local function trackViewConnection(conn)
	table.insert(viewConnections, conn)
	return conn
end

local function disconnectViewConnections()
	for _, conn in ipairs(viewConnections) do
		if conn and conn.Connected then conn:Disconnect() end
	end
	viewConnections = {}
	viewThemeRefreshers = {}
	InternalConsole.refresh = nil
end

local function applyTheme(themeName, animate)
	AppState.themeName = themeName
	Theme = Themes[themeName]

	-- Atualiza objetos vinculados
	local alive = {}
	for _, b in ipairs(themeBindings) do
		if b.inst and b.inst.Parent then
			applyProps(b.inst, { [b.prop] = Theme[b.themeKey] }, animate)
			table.insert(alive, b)
		end
	end
	themeBindings = alive

	-- Refreshers globais e da view
	for _, refresh in ipairs(globalThemeRefreshers) do
		safeCall("Theme.Global", refresh, animate)
	end
	for _, refresh in ipairs(viewThemeRefreshers) do
		safeCall("Theme.View", refresh, animate)
	end
end

local function inputPosition2(input)
	return Vector2.new(input.Position.X, input.Position.Y)
end

local function formatNumber(value, step)
	if step and step < 1 then
		return string.format("%.1f", value)
	end
	return tostring(math.floor(value + 0.5))
end

local function formatDuration(seconds)
	seconds = math.max(0, math.floor(seconds or 0))
	local hours = math.floor(seconds / 3600)
	local minutes = math.floor((seconds % 3600) / 60)
	local secs = seconds % 60

	if hours > 0 then
		return string.format("%02d:%02d:%02d", hours, minutes, secs)
	end

	return string.format("%02d:%02d", minutes, secs)
end

local function getPingMs()
	local ok, ping = pcall(function()
		return LocalPlayer:GetNetworkPing()
	end)

	if ok and type(ping) == "number" then
		return math.floor((ping * 1000) + 0.5)
	end

	return nil
end

local function shortText(value, maxLen)
	value = tostring(value or "")
	maxLen = maxLen or 14

	if #value <= maxLen then
		return value
	end

	return string.sub(value, 1, maxLen - 3) .. "..."
end

