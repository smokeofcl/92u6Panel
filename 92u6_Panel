		TextSize = 12.5,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextTruncate = Enum.TextTruncate.AtEnd,
		Parent = row,
	})
	bindTheme(titleLabel, "TextColor3", "TextHi")

	local subLabel = create("TextLabel", {
		Size = UDim2.new(1, -86, 0, 12),
		Position = UDim2.fromOffset(12, 24),
		BackgroundTransparency = 1,
		Text = opts.sub or "",
		Font = FONT_MONO,
		TextSize = 10,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextTruncate = Enum.TextTruncate.AtEnd,
		Parent = row,
	})
	bindTheme(subLabel, "TextColor3", "TextMid")

	local valueLabel = create("TextLabel", {
		Size = UDim2.fromOffset(62, 20),
		Position = UDim2.new(1, -68, 0, 7),
		Text = "",
		Font = FONT_BODY_BOLD,
		TextSize = 11,
		BorderSizePixel = 0,
		TextTransparency = 0,
		Parent = row,
	})
	bindTheme(valueLabel, "BackgroundColor3", "BgSwitchOff")
	bindTheme(valueLabel, "TextColor3", "TextHi")
	corner(valueLabel, 9)

	local sliderArea = create("TextButton", {
		Size = UDim2.new(1, -24, 0, 26),
		Position = UDim2.fromOffset(12, 34),
		BackgroundTransparency = 1,
		Text = "",
		AutoButtonColor = false,
		Parent = row,
	})
	local track = create("Frame", {
		Size = UDim2.new(1, 0, 0, 6),
		Position = UDim2.new(0, 0, 0.5, -3),
		BorderSizePixel = 0,
		Parent = sliderArea,
	})
	bindTheme(track, "BackgroundColor3", "BgSwitchOff")
	corner(track, 3)

	local fill = create("Frame", {
		Size = UDim2.new(0, 0, 1, 0),
		BorderSizePixel = 0,
		Parent = track,
	})
	corner(fill, 3)

	local handle = create("TextButton", {
		Size = UDim2.fromOffset(16, 16),
		Text = "",
		AutoButtonColor = false,
		BorderSizePixel = 0,
		Parent = sliderArea,
	})
	corner(handle, 8)
	local handleStroke = stroke(handle, Theme.BgPanel, 2)
	bindTheme(handleStroke, "Color", "BgPanel")

	local minValue = opts.min or 0
	local maxValue = opts.max or 100
	local step = opts.step or 1

	if opts.id and AppState.sliders[opts.id] == nil then
		AppState.sliders[opts.id] = opts.default or minValue
	end

	local function clampValue(value)
		value = math.clamp(value, minValue, maxValue)
		local steps = math.floor(((value - minValue) / step) + 0.5)
		return math.clamp(minValue + steps * step, minValue, maxValue)
	end

	local function getValue()
		if opts.id then return clampValue(AppState.sliders[opts.id]) end
		return clampValue(opts.default or minValue)
	end

	local function setValue(value, fireCallback, animate)
		value = clampValue(value)
		if opts.id then AppState.sliders[opts.id] = value end
		local pct = 0
		if maxValue ~= minValue then pct = (value - minValue) / (maxValue - minValue) end

		applyProps(fill, { Size = UDim2.new(pct, 0, 1, 0), BackgroundColor3 = Theme.AccentHi }, animate)
		applyProps(handle, { Position = UDim2.new(pct, -8, 0.5, -8), BackgroundColor3 = Theme.TextHi }, animate)
		valueLabel.Text = formatNumber(value, step)

		if fireCallback and opts.onChange then
			safeCall("Slider." .. tostring(opts.id or opts.title), opts.onChange, value)
		end
	end

	local dragging = false

	local function updateFromInput(input, fireCallback)
		local width = sliderArea.AbsoluteSize.X
		if width <= 0 then return end
		local pct = math.clamp((input.Position.X - sliderArea.AbsolutePosition.X) / width, 0, 1)
		setValue(minValue + pct * (maxValue - minValue), fireCallback, false)
	end

	addViewThemeRefresher(function() setValue(getValue(), false, false) end)

	local function beginDrag(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			updateFromInput(input, true)
		end
	end

	sliderArea.InputBegan:Connect(beginDrag)
	handle.InputBegan:Connect(beginDrag)

	trackViewConnection(UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end))

	trackViewConnection(UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			updateFromInput(input, true)
		end
	end))

	setValue(getValue(), false, false)
	return row
end

function rerenderActiveView(animate)
	local meta = ViewMeta and ViewMeta[AppState.activeView]
	if not meta then
		return
	end

	noticeToken += 1
	ContentTitle.Text = meta.title
	ContentDesc.Text = meta.desc
	clearContent()
	safeCall("View." .. AppState.activeView, meta.render)
	refreshNavVisuals(animate == true)
end

