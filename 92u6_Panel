local function showLoadingNotification(onComplete)
	AppState.isLoading = true
	setInterfaceEnabled(true)
	Panel.Visible = false
	if LoginFrame then LoginFrame.Visible = false end
	LoadingNotification.Visible = true
	LoadingNotification.Position = UDim2.new(1, -18, 1, 96)
	loadingProgress.Size = UDim2.new(0, 0, 1, 0)
	tween(LoadingNotification, { Position = UDim2.new(1, -18, 1, -18) }, 0.28)

	task.spawn(function()
		local start = os.clock()
		setLoadingProgress(0.08)
		waitLoadingStep()

		if not game:IsLoaded() then
			loadingMessage.Text = "Carregando Interface"
			game.Loaded:Wait()
		end
		setLoadingProgress(0.28)
		waitLoadingStep()

		loadingMessage.Text = "Carregando Funções"
		preloadLoadingAssets()
		setLoadingProgress(0.52)
		waitLoadingStep()

		loadingMessage.Text = "Carregando essenciais"
		updatePanelScale()
		applyTheme(AppState.themeName, false)
		setLoadingProgress(0.72)
		waitLoadingStep()

		loadingMessage.Text = "Finalizado"
		waitForContentQueue()
		setLoadingProgress(0.9)

		local elapsed = os.clock() - start
		local rem = CONFIG.Loading.MinDuration - elapsed
		if rem > 0 then task.wait(rem) end

		loadingMessage.Text = CONFIG.Loading.Message
		setLoadingProgress(1)
		task.wait(0.38)

		tween(LoadingNotification, { Position = UDim2.new(1, -18, 1, 96) }, 0.24)
		task.delay(0.26, function()
			LoadingNotification.Visible = false
			AppState.isLoading = false
			Cheat.start()
			if onComplete then onComplete() end
		end)
	end)
end

