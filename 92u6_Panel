-- 16. TECLA DE ATALHO CONFIGURAVEL E ARRASTE
-- ============================================================
UserInputService.InputBegan:Connect(function(input, gp)
	safeCall("Hotkey.Toggle", function()
		if gp then return end
		if AppState.isLoading then return end
		if input.UserInputType ~= Enum.UserInputType.Keyboard then return end

		if AppState.waitingForKey then
			if input.KeyCode == Enum.KeyCode.Unknown then return end
			if input.KeyCode == AppState.toggleKey then
				showNotice("Essa tecla abre o painel. Escolha outra.")
				return
			end

			local keyId = AppState.waitingForKey
			for otherId, keyCode in pairs(AppState.keybinds) do
				if otherId ~= keyId and keyCode == input.KeyCode then
					AppState.keybinds[otherId] = Enum.KeyCode.Unknown
				end
			end
			AppState.keybinds[keyId] = input.KeyCode
			AppState.waitingForKey = nil
			saveKeybinds()

			if ScreenGui.Enabled then
				rerenderActiveView(false)
				showNotice("Tecla salva: " .. keyText(input.KeyCode) .. ".")
			end
			return
		end

		if input.KeyCode == AppState.toggleKey then
			if AppState.isLoggedIn then
				if ScreenGui.Enabled then
					setInterfaceEnabled(false)
				else
					showPanelCentered()
				end
			else
				if ScreenGui.Enabled then
					setInterfaceEnabled(false)
				else
					showLoginCentered()
				end
			end
			return
		end

		if not AppState.isLoggedIn then
			return
		end

		for id, keyCode in pairs(AppState.keybinds) do
			if keyCode == input.KeyCode and keyCode ~= Enum.KeyCode.Unknown then
				setFeatureToggle(id, not (AppState.toggles[id] == true))
				if ScreenGui.Enabled and (AppState.activeView == "Visuals" or AppState.activeView == "Combat") then
					rerenderActiveView(false)
				end
				return
			end
		end
	end)
end)

-- Arraste do painel
do
	local dragging = false
	local dragStart, startPos

	local function beginPanelDrag(input)
		safeCall("Drag.Begin", function()
			if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then
				return
			end
			dragging = true
			dragStart = inputPosition2(input)
			startPos = Panel.Position
			input.Changed:Connect(function()
				safeCall("Drag.End", function()
					if input.UserInputState == Enum.UserInputState.End then
						dragging = false
					end
				end)
			end)
		end)
	end

	Titlebar.InputBegan:Connect(beginPanelDrag)
	DragHandle.InputBegan:Connect(beginPanelDrag)

	UserInputService.InputChanged:Connect(function(input)
		safeCall("Drag.Move", function()
			if not dragging then return end
			if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then
				return
			end
			local delta = inputPosition2(input) - dragStart
			Panel.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end)
	end)
end

