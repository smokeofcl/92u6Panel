local viewportConnection

local function bindViewportWatcher()
	if viewportConnection and viewportConnection.Connected then
		viewportConnection:Disconnect()
	end
	local cam = Workspace.CurrentCamera
	if cam then
		viewportConnection = cam:GetPropertyChangedSignal("ViewportSize"):Connect(function()
			safeCall("Viewport.Resize", updatePanelScale)
		end)
	end
	safeCall("Viewport.Resize", updatePanelScale)
end

Workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()
	safeCall("Viewport.CameraChanged", bindViewportWatcher)
end)
safeCall("Viewport.Bind", bindViewportWatcher)

