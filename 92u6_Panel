function setLoginStatus(text, isError)
	loginStatus.Text = text
	loginStatusIsError = isError == true
	refreshLoginStatus()
end

local function trimCredentialText(text)
	return tostring(text or ""):match("^%s*(.-)%s*$")
end

local function credentialIsValid(username, token)
	username = trimCredentialText(username)
	token = trimCredentialText(token)

	for _, credential in ipairs(CONFIG.Login.Credentials or {}) do
		local validUsername = trimCredentialText(credential.Username)
		local validToken = trimCredentialText(credential.Token)

		if validUsername ~= "" and validToken ~= "" and username == validUsername and token == validToken then
			return true
		end
	end

	return false
end

local function tryLogin()
	if credentialIsValid(usernameBox.Text, tokenBox.Text) then
		AppState.isLoggedIn = true
		LoginFrame.Visible = false
		setLoginStatus("acesso liberado", false)
		showPanelCentered()
	else
		setLoginStatus("usuário ou token inválido", true)
		tween(LoginFrame, { Position = UDim2.new(0.5, -6, 0.5, 0) }, 0.05)
		task.delay(0.06, centerLogin)
	end
end

