CONFIG.Login.PutDiscordInChat = function()
	local invite = CONFIG.Login.DiscordInvite

	pcall(function()
		StarterGui:SetCore("ChatActive", true)
	end)

	task.wait(0.05)

	local roots = { PlayerGui }
	pcall(function()
		table.insert(roots, game:GetService("CoreGui"))
	end)

	local function looksLikeChatBox(obj)
		if not obj:IsA("TextBox") then
			return false
		end

		local panelGui = PlayerGui:FindFirstChild("Panel92u6UI")
		if panelGui and obj:IsDescendantOf(panelGui) then
			return false
		end

		local name = string.lower(obj.Name)
		local parentName = obj.Parent and string.lower(obj.Parent.Name) or ""
		local placeholder = string.lower(obj.PlaceholderText or "")

		return name:find("chat") ~= nil
			or parentName:find("chat") ~= nil
			or placeholder:find("chat") ~= nil
	end

	for _, root in ipairs(roots) do
		for _, obj in ipairs(root:GetDescendants()) do
			if looksLikeChatBox(obj) then
				local ok = pcall(function()
					obj.Text = invite
					obj:CaptureFocus()
					obj.CursorPosition = #invite + 1
				end)

				if ok then
					return true
				end
			end
		end
	end

	return false
end

-- ============================================================
-- 3. MÓDULO CHEAT (LÓGICA DO HACK) - CORRIGIDO TRACER
-- ============================================================
local Cheat = {}
do
	-- Parâmetros internos
	local CONFIG_CHEAT = {
		FOV_ANGLE = 30,
		CIRCLE_RADIUS = 80,
		CIRCLE_MIN = 20,
		CIRCLE_MAX = 300,
		TRACER_WIDTH = 0.04,
		TRACER_COLOR = Color3.fromRGB(255, 0, 0),
		ESP_COLOR = Color3.fromRGB(255, 0, 0),
		ESP_BAR_WIDTH = 3,
		ESP_MIN_HEIGHT = 20,
		ESP_MAX_HEIGHT = 200,
		HIGHLIGHT_FILL = Color3.fromRGB(255, 0, 0),
		HIGHLIGHT_OUTLINE = Color3.fromRGB(255, 255, 255),
	}

	-- Estados
	local aimbot = false
	local tracers = false
	local hitbox = false
	local circle = false
	local highlight = false
	local teamCheckAimbot = false
	local targetHead = nil

	-- Armazenamentos
	local screenGui = nil
	local fovCircle = nil
	local espStorage = {}      -- [player] = {box, healthBg, healthFill}
	local tracerStorage = {}   -- [player] = {beam, attachTarget}
	local highlightStorage = {} -- [character] = Highlight
	local localAttachment = nil
	local renderConnection = nil

	-- Funções auxiliares locais
	local function sameTeam(plr)
		return plr and LocalPlayer and plr.Team == LocalPlayer.Team
	end

	local function angleBetween(v1, v2)
		local dot = v1:Dot(v2) / (v1.Magnitude * v2.Magnitude)
		return math.acos(math.clamp(dot, -1, 1))
	end

	local function getClosestEnemy(useTeamCheck)
		local char = LocalPlayer.Character
		if not char or not char:FindFirstChild("Head") then return nil end
		local camPos = Camera.CFrame.Position
		local camLook = Camera.CFrame.LookVector
		local screenCenter = Camera.ViewportSize / 2
		local best = { distance = math.huge, head = nil }

		for _, other in ipairs(Players:GetPlayers()) do
			if other ~= LocalPlayer then
				if useTeamCheck and sameTeam(other) then continue end
				local otherChar = other.Character
				if otherChar and otherChar:FindFirstChild("Head") and otherChar:FindFirstChild("Humanoid") and otherChar.Humanoid.Health > 0 then
					local head = otherChar.Head
					if circle then
						local screenPos, onScreen = Camera:WorldToScreenPoint(head.Position)
						if onScreen and (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude <= CONFIG_CHEAT.CIRCLE_RADIUS then
							local dist3D = (head.Position - camPos).Magnitude
							if dist3D < best.distance then best = { distance = dist3D, head = head } end
						end
					else
						local dir = (head.Position - camPos).Unit
						local ang = math.deg(angleBetween(camLook, dir))
						if ang <= CONFIG_CHEAT.FOV_ANGLE then
							local dist3D = (head.Position - camPos).Magnitude
							if dist3D < best.distance then best = { distance = dist3D, head = head } end
						end
					end
				end
			end
		end
		return best.head
	end

	-- Setters públicos
	function Cheat.setAimbot(enabled) aimbot = enabled end
	function Cheat.setTracers(enabled)
		tracers = enabled
		if not enabled then
			for plr, data in pairs(tracerStorage) do
				if data.beam then data.beam:Destroy() end
				if data.attachTarget then data.attachTarget:Destroy() end
				tracerStorage[plr] = nil
			end
		end
	end
	function Cheat.setHitbox(enabled)
		hitbox = enabled
		if not enabled then
			for plr in pairs(espStorage) do
				local e = espStorage[plr]
				if e then e.box:Destroy(); e.healthBg:Destroy(); e.healthFill:Destroy() end
				espStorage[plr] = nil
			end
		end
	end
	function Cheat.setCircle(enabled)
		circle = enabled
		if fovCircle then fovCircle.Visible = enabled end
	end
	function Cheat.setCircleRadius(radius)
		CONFIG_CHEAT.CIRCLE_RADIUS = math.clamp(radius, CONFIG_CHEAT.CIRCLE_MIN, CONFIG_CHEAT.CIRCLE_MAX)
		if fovCircle then
			fovCircle.Size = UDim2.new(0, CONFIG_CHEAT.CIRCLE_RADIUS * 2, 0, CONFIG_CHEAT.CIRCLE_RADIUS * 2)
			fovCircle.Position = UDim2.new(0.5, -CONFIG_CHEAT.CIRCLE_RADIUS, 0.5, -CONFIG_CHEAT.CIRCLE_RADIUS)
		end
	end
	function Cheat.setTeamCheckAimbot(enabled) teamCheckAimbot = enabled end

	function Cheat.setHighlight(enabled)
		highlight = enabled
		if not enabled then
			for plr, hl in pairs(highlightStorage) do
				if hl and hl.Parent then hl:Destroy() end
				highlightStorage[plr] = nil
			end
		else
			for _, plr in ipairs(Players:GetPlayers()) do
				if plr ~= LocalPlayer and plr.Character then
					Cheat.addHighlightToCharacter(plr.Character)
				end
			end
		end
	end

	function Cheat.addHighlightToCharacter(character)
		if not character or highlightStorage[character] then return end
		local hl = Instance.new("Highlight")
		hl.FillColor = CONFIG_CHEAT.HIGHLIGHT_FILL
		hl.OutlineColor = CONFIG_CHEAT.HIGHLIGHT_OUTLINE
		hl.FillTransparency = 0.3
		hl.OutlineTransparency = 0
		hl.Parent = character
		highlightStorage[character] = hl
	end

	function Cheat.removeHighlightFromCharacter(character)
		local hl = highlightStorage[character]
		if hl then hl:Destroy(); highlightStorage[character] = nil end
	end

	-- Iniciar / Parar o loop
	function Cheat.start()
		if screenGui then return end
		screenGui = Instance.new("ScreenGui", LocalPlayer:WaitForChild("PlayerGui"))
		screenGui.Name = "CheatOverlay"
		screenGui.ResetOnSpawn = false

		-- Círculo FOV
		fovCircle = Instance.new("Frame", screenGui)
		fovCircle.Size = UDim2.new(0, CONFIG_CHEAT.CIRCLE_RADIUS * 2, 0, CONFIG_CHEAT.CIRCLE_RADIUS * 2)
		fovCircle.Position = UDim2.new(0.5, -CONFIG_CHEAT.CIRCLE_RADIUS, 0.5, -CONFIG_CHEAT.CIRCLE_RADIUS)
		fovCircle.BackgroundTransparency = 1
		fovCircle.BorderSizePixel = 0
		fovCircle.Visible = circle
		fovCircle.ZIndex = 10
		local stroke = Instance.new("UIStroke", fovCircle)
		stroke.Color = Color3.fromRGB(255, 255, 255)
		stroke.Thickness = 1.5
		stroke.LineJoinMode = Enum.LineJoinMode.Round
		Instance.new("UICorner", fovCircle).CornerRadius = UDim.new(1, 0)

		-- Evento para limpar attachment quando o personagem morre
		LocalPlayer.CharacterRemoving:Connect(function()
			if localAttachment then
				localAttachment:Destroy()
				localAttachment = nil
			end
		end)

		-- Eventos de jogador
		Players.PlayerAdded:Connect(function(plr)
			if highlight then
				plr.CharacterAdded:Connect(function(char) Cheat.addHighlightToCharacter(char) end)
				if plr.Character then Cheat.addHighlightToCharacter(plr.Character) end
			end
		end)

		Players.PlayerRemoving:Connect(function(plr)
			if plr.Character then Cheat.removeHighlightFromCharacter(plr.Character) end
			if espStorage[plr] then
				local e = espStorage[plr]; e.box:Destroy(); e.healthBg:Destroy(); e.healthFill:Destroy()
				espStorage[plr] = nil
			end
			if tracerStorage[plr] then
				local d = tracerStorage[plr]
				if d.beam then d.beam:Destroy() end
				if d.attachTarget then d.attachTarget:Destroy() end
				tracerStorage[plr] = nil
			end
		end)

		-- Loop principal
		renderConnection = RunService.RenderStepped:Connect(function()
			targetHead = getClosestEnemy(teamCheckAimbot)
			local localChar = LocalPlayer.Character

			-- Aimbot
			if aimbot and targetHead then
				Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetHead.Position)
			end

			-- Tracers (CORRIGIDO)
			if tracers then
				-- Verifica se o personagem local existe e tem HumanoidRootPart
				if localChar and localChar:FindFirstChild("HumanoidRootPart") then
					-- Recria o attachment se ele não existir ou foi destruído
					if not localAttachment or not localAttachment.Parent or not localAttachment:IsDescendantOf(Workspace) then
						if localAttachment then
							localAttachment:Destroy()
						end
						localAttachment = Instance.new("Attachment", localChar.HumanoidRootPart)
					end
				else
					-- Se não tem personagem, limpa o attachment
					if localAttachment then
						localAttachment:Destroy()
						localAttachment = nil
					end
				end

				-- Para cada jogador inimigo
				for _, other in ipairs(Players:GetPlayers()) do
					if other ~= LocalPlayer then
						local char = other.Character
						if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
							if teamCheckAimbot and sameTeam(other) then
								if tracerStorage[other] then
									local d = tracerStorage[other]
									if d.beam then d.beam:Destroy() end
									if d.attachTarget then d.attachTarget:Destroy() end
									tracerStorage[other] = nil
								end
								continue
							end
							local root = char.HumanoidRootPart
							if not tracerStorage[other] then
								local attachTarget = Instance.new("Attachment", root)
								local beam = Instance.new("Beam", Workspace)
								beam.Color = ColorSequence.new(CONFIG_CHEAT.TRACER_COLOR)
								beam.Width0 = CONFIG_CHEAT.TRACER_WIDTH
								beam.Width1 = CONFIG_CHEAT.TRACER_WIDTH
								beam.FaceCamera = true
								beam.Transparency = NumberSequence.new(0)
								beam.Enabled = false
								tracerStorage[other] = { beam = beam, attachTarget = attachTarget }
							end
							local d = tracerStorage[other]
							if d.beam and d.attachTarget and localAttachment then
								d.attachTarget.Parent = root
								d.beam.Attachment0 = localAttachment
								d.beam.Attachment1 = d.attachTarget
								d.beam.Enabled = true
							end
						else
							if tracerStorage[other] then
								local d = tracerStorage[other]
								if d.beam then d.beam:Destroy() end
								if d.attachTarget then d.attachTarget:Destroy() end
								tracerStorage[other] = nil
							end
						end
					end
				end
			else
				-- Se tracers desligado, limpa tudo
				for plr, d in pairs(tracerStorage) do
					if d.beam then d.beam:Destroy() end
					if d.attachTarget then d.attachTarget:Destroy() end
					tracerStorage[plr] = nil
				end
				if localAttachment then
					localAttachment:Destroy()
					localAttachment = nil
				end
			end

			-- Hitbox (ESP)
			if hitbox then
				for _, p in ipairs(Players:GetPlayers()) do
					if p ~= LocalPlayer then
						local char = p.Character
						if char and char:FindFirstChild("Head") and char:FindFirstChild("Humanoid") and char:FindFirstChild("HumanoidRootPart") and char.Humanoid.Health > 0 then
							if not espStorage[p] then
								local box = Instance.new("Frame", screenGui)
								box.BackgroundTransparency = 1
								box.BorderSizePixel = 0
								box.Visible = false
								box.ZIndex = 4
								box.AnchorPoint = Vector2.new(0.5, 0.5)
								local boxStroke = Instance.new("UIStroke", box)
								boxStroke.Color = CONFIG_CHEAT.ESP_COLOR
								boxStroke.Thickness = 1.5
								boxStroke.LineJoinMode = Enum.LineJoinMode.Miter
								local healthBg = Instance.new("Frame", screenGui)
								healthBg.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
								healthBg.BorderSizePixel = 0
								healthBg.Visible = false
								healthBg.ZIndex = 4
								local healthFill = Instance.new("Frame", screenGui)
								healthFill.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
								healthFill.BorderSizePixel = 0
								healthFill.Visible = false
								healthFill.ZIndex = 5
								espStorage[p] = { box = box, healthBg = healthBg, healthFill = healthFill }
							end
							local e = espStorage[p]
							local hPos = char.Head.Position + Vector3.new(0, 1.5, 0)
							local fPos = char.HumanoidRootPart.Position - Vector3.new(0, 3, 0)
							local hScr, hVis = Camera:WorldToScreenPoint(hPos)
							local fScr, fVis = Camera:WorldToScreenPoint(fPos)
							if hVis and fVis then
								local height = math.clamp(math.abs(hScr.Y - fScr.Y), CONFIG_CHEAT.ESP_MIN_HEIGHT, CONFIG_CHEAT.ESP_MAX_HEIGHT)
								local width = height * 0.6
								local cx = (hScr.X + fScr.X) / 2
								local cy = (hScr.Y + fScr.Y) / 2
								e.box.Size = UDim2.new(0, width, 0, height)
								e.box.Position = UDim2.new(0, cx, 0, cy)
								e.box.Visible = true
								local barLeft = cx - width/2 - CONFIG_CHEAT.ESP_BAR_WIDTH - 2
								local barTop = cy - height/2
								e.healthBg.Size = UDim2.new(0, CONFIG_CHEAT.ESP_BAR_WIDTH, 0, height)
								e.healthBg.Position = UDim2.new(0, barLeft, 0, barTop)
								e.healthBg.Visible = true
								local pct = char.Humanoid.Health / char.Humanoid.MaxHealth
								local fillH = height * pct
								e.healthFill.Size = UDim2.new(0, CONFIG_CHEAT.ESP_BAR_WIDTH, 0, fillH)
								e.healthFill.Position = UDim2.new(0, barLeft, 0, barTop + height - fillH)
								e.healthFill.Visible = true
								e.healthFill.BackgroundColor3 = pct > 0.5 and Color3.fromRGB(0,255,0) or (pct > 0.25 and Color3.fromRGB(255,255,0) or Color3.fromRGB(255,0,0))
							else
								e.box.Visible = false; e.healthBg.Visible = false; e.healthFill.Visible = false
							end
						else
							if espStorage[p] then
								local e = espStorage[p]; e.box:Destroy(); e.healthBg:Destroy(); e.healthFill:Destroy()
								espStorage[p] = nil
							end
						end
					end
				end
			else
				for plr, e in pairs(espStorage) do
					e.box:Destroy(); e.healthBg:Destroy(); e.healthFill:Destroy()
					espStorage[plr] = nil
				end
			end
		end)
	end

	function Cheat.stop()
		if renderConnection then renderConnection:Disconnect(); renderConnection = nil end
		for plr, d in pairs(tracerStorage) do
			if d.beam then d.beam:Destroy() end
			if d.attachTarget then d.attachTarget:Destroy() end
			tracerStorage[plr] = nil
		end
		if localAttachment then localAttachment:Destroy(); localAttachment = nil end
		for plr, e in pairs(espStorage) do
			e.box:Destroy(); e.healthBg:Destroy(); e.healthFill:Destroy()
			espStorage[plr] = nil
		end
		for _, hl in pairs(highlightStorage) do
			if hl and hl.Parent then hl:Destroy() end
		end
		highlightStorage = {}
		if fovCircle then fovCircle:Destroy(); fovCircle = nil end
		if screenGui then screenGui:Destroy(); screenGui = nil end
		aimbot = false; tracers = false; hitbox = false; circle = false; highlight = false
		teamCheckAimbot = false
	end
end

