local function scheduleDiscordModalHide()
	discordManualToken += 1
	local token = discordManualToken

	task.delay(4, function()
		if token ~= discordManualToken then
			return
		end

		discordModal.Visible = false
		discordCopied = false
		modalCopyButton.Text = "Copiar"
		refreshDiscordButton(false)
		setLoginStatus("digite o token para liberar o painel", false)
	end)
end

local function tryCopyDiscordModalLink()
	local copied = false
	local clipboardFn = setclipboard or toclipboard

	if type(clipboardFn) == "function" then
		copied = pcall(function()
			clipboardFn(CONFIG.Login.DiscordInvite)
		end)
	end

	focusDiscordModalLink()

	if copied then
		discordModalStatus.Text = "copiado"
		modalCopyButton.Text = "Copiado"
		setLoginStatus("link copiado", false)
	else
		discordModalStatus.Text = "use Ctrl+C agora"
		modalCopyButton.Text = "Ctrl+C"
		setLoginStatus("link selecionado para copiar", false)
	end

	scheduleDiscordModalHide()
	return copied
end

function showDiscordManualLink()
	discordCopied = false
	discordLinkBox.Text = CONFIG.Login.DiscordInvite
	discordModalStatus.Text = "fecha em 4 segundos"
	modalCopyButton.Text = "Copiar"
	discordModal.Visible = true
	refreshDiscordButton(false)
	setLoginStatus("link selecionado para copiar", false)

	task.defer(focusDiscordModalLink)
	scheduleDiscordModalHide()
end

