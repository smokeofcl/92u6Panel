local function openView(name)
	local meta = ViewMeta[name]
	if not meta then return end
	AppState.waitingForKey = nil
	noticeToken = noticeToken + 1
	AppState.activeView = name
	ContentTitle.Text = meta.title
	ContentDesc.Text = meta.desc
	clearContent()
	safeCall("View." .. name, meta.render)
	refreshNavVisuals(true)
end

