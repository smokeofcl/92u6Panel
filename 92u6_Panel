local function showNotice(text)
	noticeToken = noticeToken + 1
	local token = noticeToken
	ContentDesc.Text = text
	task.delay(2, function()
		if token ~= noticeToken then return end
		local meta = ViewMeta and ViewMeta[AppState.activeView]
		if meta then ContentDesc.Text = meta.desc end
	end)
end

local function refreshNavVisuals(animate)
	for name, refs in pairs(navButtons) do
		local active = AppState.activeView == name
		applyProps(refs.button, {
			BackgroundColor3 = Theme.AccentWash,
			BackgroundTransparency = active and SURFACE_GLASS_TRANSPARENCY or 1,
		}, animate)
		applyProps(refs.label, { TextColor3 = active and Theme.AccentHi or Theme.TextMid }, animate)
		if refs.icon then
			if refs.icon:IsA("ImageLabel") then
				local imageProps = {
					ImageTransparency = active and 0 or 0.18,
				}
				if refs.iconTint then
					imageProps.ImageColor3 = active and Theme.AccentHi or Theme.TextMid
				end
				applyProps(refs.icon, imageProps, animate)
			else
				applyProps(refs.icon, { TextColor3 = active and Theme.AccentHi or Theme.TextMid }, animate)
			end
		end
		refs.bar.Visible = active
		refs.stroke.Transparency = active and 0 or 1
		refs.stroke.Color = Theme.Accent
	end
	local settingsActive = AppState.activeView == "Settings"
	applyProps(SettingsBtn, {
		BackgroundColor3 = Theme.AccentWash,
		BackgroundTransparency = settingsActive and SURFACE_GLASS_TRANSPARENCY or 1,
		TextColor3 = settingsActive and Theme.AccentHi or Theme.TextMid,
	}, animate)
	settingsStroke.Transparency = settingsActive and 0 or 1
	settingsStroke.Color = Theme.Accent
end
